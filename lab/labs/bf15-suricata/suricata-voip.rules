# VoIPSec BF15 — Suricata IDS rules for VoIP/SIP threats (local sid range 9000000+).
# Detect stage of the M13(attack) -> detect -> M15(respond) pipeline. Alerts are consumed by
# eve-to-ipset.sh, which feeds offending sources into the same nftables blocklist as the honeypot.
# Threat mapping (VoIPSA taxonomy): recon/service-abuse + intentional interruption of service (DoS).

# --- Reconnaissance: known scanner User-Agents (T7) ---
alert sip any any -> $HOME_NET any (msg:"VOIPSEC SIP scanner UA (SIPVicious friendly-scanner)"; content:"friendly-scanner"; nocase; classtype:attempted-recon; sid:9000001; rev:1;)
alert sip any any -> $HOME_NET any (msg:"VOIPSEC SIP scanner UA (sipvicious/sipcli/sundayddr)"; pcre:"/User-Agent\s*:\s*.*(sipvicious|sipcli|sundayddr|VaxSIPUserAgent|sip-scan)/i"; classtype:attempted-recon; sid:9000002; rev:1;)

# --- Enumeration: OPTIONS sweep across many targets from one source (T7) ---
alert sip any any -> $HOME_NET any (msg:"VOIPSEC SIP OPTIONS sweep (enumeration)"; sip.method; content:"OPTIONS"; threshold:type both, track by_src, count 20, seconds 10; classtype:attempted-recon; sid:9000003; rev:1;)

# --- Credential attack: REGISTER brute-force / flood (T3/T4) ---
alert sip any any -> $HOME_NET any (msg:"VOIPSEC SIP REGISTER flood/brute-force"; sip.method; content:"REGISTER"; threshold:type both, track by_src, count 30, seconds 10; classtype:attempted-dos; sid:9000004; rev:1;)

# --- Denial of service: INVITE flood (T1) ---
alert sip any any -> $HOME_NET any (msg:"VOIPSEC SIP INVITE flood (DoS)"; sip.method; content:"INVITE"; threshold:type both, track by_src, count 40, seconds 10; classtype:attempted-dos; sid:9000005; rev:1;)

# --- Service abuse: toll-fraud dial pattern to international premium prefixes (T4) ---
alert sip any any -> $HOME_NET any (msg:"VOIPSEC possible toll-fraud dial (intl/premium prefix)"; sip.method; content:"INVITE"; sip.uri; pcre:"/^sip:\+?(00|011)(53|239|248|252|373|881|882|900|976)/i"; classtype:policy-violation; sid:9000006; rev:1;)

# --- Malformed/oversized SIP (parser abuse, cf. RFC 4475 torture) (T10) ---
alert sip any any -> $HOME_NET any (msg:"VOIPSEC oversized SIP request line (possible fuzzing)"; sip.request_line; dsize:>1500; classtype:protocol-command-decode; sid:9000007; rev:1;)
