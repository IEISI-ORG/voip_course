# SOVOC lab environment — copy to `.env` and edit. NEVER commit `.env` (it is gitignored).
# Real secrets (SIP passwords, TLS key passphrases, API tokens) live only in `.env`
# and generated files under `secrets/`, never in tracked config.

# --- Image version pins (verify against upstream before a cohort runs) ---
# Each Stage-A iteration sets the real pinned tag/ref (verify against upstream).
KAMAILIO_TAG=5.8-alpine
RTPENGINE_REF=mr12.5.1.1
ASTERISK_TAG=placeholder
FREESWITCH_TAG=placeholder
HOMER_TAG=placeholder
PROMETHEUS_TAG=placeholder
GRAFANA_TAG=placeholder
LOKI_TAG=placeholder
WAZUH_TAG=placeholder

# --- Lab domain / addressing ---
SIP_DOMAIN=lab.sovoc.test
EDGE_SBC_IP=172.28.10.10

# --- edge-sbc (Kamailio) ---
# topoh topology-hiding mask secret. Generate: openssl rand -hex 16
TOPOH_MASK_SECRET=change-me

# --- Credentials (examples — regenerate real ones into .env) ---
# Generate strong values, e.g.:  openssl rand -base64 24
SIP_ALICE_SECRET=change-me
SIP_BOB_SECRET=change-me
TRUNK_SECRET=change-me
GRAFANA_ADMIN_PASSWORD=change-me

# --- TLS / PKI ---
# Private CA (step-ca) material is generated into pki/ at bootstrap; not committed.
TLS_KEY_PASSPHRASE=change-me
